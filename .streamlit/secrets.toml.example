# Template only -- safe to commit. Copy to .streamlit/secrets.toml (which is
# gitignored) and fill in real values. Never commit the copy.

# Required for a PUBLIC build (PGI_PUBLIC_BUILD=1): the salt used to compute
# anonymized pseudonyms for named buyer/supplier IDs. Generate a long random
# string once per deployment (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`)
# and keep it secret -- anyone who has both the source code and this value
# could recompute the same pseudonym mapping. Rotating it changes every
# pseudonym a viewer has seen.
#
# Without this set, a PUBLIC_BUILD deployment refuses to start rather than
# fall back to the hardcoded development salt in src/dashboard/_auth.py.
anon_salt = "REPLACE_WITH_A_LONG_RANDOM_SECRET"
