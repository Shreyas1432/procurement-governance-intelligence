# Data — never commit raw or processed data
data/raw/
data/curated/
data/features/
data/models/
data/results/

# Generated dist — rebuilt by make strip
dist/

# Environment
.venv/
*.env
.env

# Streamlit secrets — never commit (auth store salt, anonymization salt,
# future API keys). .streamlit/config.toml and
# .streamlit/secrets.toml.example ARE safe to commit and are not covered by
# this rule.
.streamlit/secrets.toml

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Jupyter checkpoints
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Kaleido temp files
orca_config.json

# Dataset — never commit the 12M-row parquet or raw files
Dataset/

