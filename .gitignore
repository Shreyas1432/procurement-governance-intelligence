# Data — never commit raw or processed data
data/raw/
data/curated/
data/features/
data/models/
data/results/

# Generated dist — rebuilt by make strip
dist/

# Environment
.venv/
*.env
.env

# Streamlit secrets — never commit (auth store salt, anonymization salt,
# future API keys). .streamlit/config.toml and
# .streamlit/secrets.toml.example ARE safe to commit and are not covered by
# this rule.
.streamlit/secrets.toml

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Jupyter checkpoints
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Kaleido temp files
orca_config.json

# Dataset — never commit the 12M-row parquet or raw files
Dataset/

# personal / agent / memory
.claude/
.codex/
CLAUDE.md
claude_memory.md
project_memory.md
PGI_PROJECT_STATE.md
scratch/
archive/
graphify-out/

# internal reports & diff-specs (hand-applied, not for repo)
REMEDIATION_REPORT.md
update_docs.py
docs/memory/
docs/supervisor_updates/
docs/EXAMINER_DEMOLITION_REPORT.md
docs/PASS5_ROLLBACK_AND_DIFFSPECS.md
docs/REFACTOR_PLAN.md
docs/refactor_summary.md
docs/repository_audit.md
docs/*_diffs.md

# thesis lives in Overleaf, per your rule
docs/Thesis_Report.tex
docs/references.bib

# raw dataset — never commit large parquets
*.parquet

# data/public/ is the pseudonymized-at-rest mirror for the Streamlit Cloud
# public build (see scripts/build_public_data.py, DEPLOY.md Path 1) --
# un-ignore it despite the blanket *.parquet rule above. data/raw/,
# data/curated/, data/features/, data/models/, data/results/ (the real,
# unpseudonymized directories) stay excluded by the rules at the top.
!data/public/**

# src/dashboard/ tracked selectively: source only. Secrets, auth store,
# logs, and the stray nested .streamlit/ (unrelated app_password key,
# see DEPLOY.md) stay excluded.
src/dashboard/_auth_store.json
src/dashboard/logs/
src/dashboard/.streamlit/

# Generated plot outputs (rebuilt by make figures)
results/
outputs/
reports/
refactor/

# The bare "results/" rule above matches ANY path component named "results"
# (unanchored), which excludes the data/public/results/ DIRECTORY itself --
# git won't look inside an excluded directory for negated file patterns, so
# the directory has to be un-excluded too, not just its contents.
!data/public/results/
!data/public/results/**

# Temp dirs
duckdb_temp/
tmp_pip/
.pytest_cache/
.ruff_cache/
